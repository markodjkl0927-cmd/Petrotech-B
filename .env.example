# Database
DATABASE_URL=postgresql://...

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Resend SMTP (transactional email)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_your_api_key_here
# Use quotes — the & and <> characters break parsing if unquoted on some hosts
SMTP_FROM="R&P Global Energies <noreply@randpglobalenergies.com>"
# Safe alternative if FROM still fails: SMTP_FROM=noreply@randpglobalenergies.com

# R&P admin notifications
RP_DEALERSHIP_NOTIFY_EMAIL=admin@randpglobalenergies.com
RP_ADMIN_EMAIL=admin@randpglobalenergies.com
