# Database
DATABASE_URL=postgresql://...

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Resend (transactional email)
# On Render, use the HTTP API key — SMTP port 587 is blocked (ETIMEDOUT).
RESEND_API_KEY=re_your_api_key_here
SMTP_FROM=noreply@randpglobalenergies.com

# Optional legacy SMTP (local dev only; blocked on Render)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here

# R&P admin notifications (inbox for new applications)
RP_DEALERSHIP_NOTIFY_EMAIL=admin@randpglobalenergies.com
RP_CAREER_NOTIFY_EMAIL=admin@randpglobalenergies.com
RP_ADMIN_EMAIL=admin@randpglobalenergies.com

# Password reset links in emails
RP_PORTAL_URL=https://randpglobalenergies.com

# AWS S3 — career resume storage (see AWS_S3_SETUP.md)
AWS_REGION=us-east-1
AWS_S3_BUCKET=rp-randp-career-resumes-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_RESUME_PREFIX=rp/careers
AWS_S3_SIGNED_URL_EXPIRES_SEC=3600
